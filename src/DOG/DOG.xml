<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.jkitzmann</category>
    <title>DifferenceOfGaussians</title>
    <description>
        Difference of Gaussians image edge detection.
    </description>
    <version>0.0.1</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Hans J. Johnson, Jacob J. Kitzmann</contributor>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>inputVolume</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>outputVolume</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered volume</description>
        </image>
    </parameters>

    <parameters>
        <label>Smoothing</label>
        <description>Smoothing parameters</description>
        <float>
            <name>sigma1</name>
            <longflag>sigma1</longflag>
            <label>Sigma One</label>
            <description>First sigma for difference of gaussians. This gaussian is subtracted from the sigma 2 Gaussian.</description>
        </float>
        <float>
            <name>sigma2</name>
            <longflag>sigma2</longflag>
            <label>Sigma Two</label>
            <description>Second sigma for difference of gaussians. This sigma should be greater than  sigma one.</description>
        </float>
    </parameters>
</executable>
