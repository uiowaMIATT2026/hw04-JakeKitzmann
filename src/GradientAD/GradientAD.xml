<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.jkitzmann</category>
    <title>GradientAD</title>
    <description>
        Gradient based anisotropic diffusion smoothing
    </description>
    <version>0.0.1</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Hans J. Johnson, Jacob J. Kitzmann</contributor>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>inputVolume</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
            <default>in.nii.gz</default>
        </image>
        <image>
            <name>outputVolume</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered volume</description>
            <default>filtered.nii.gz</default>
        </image>
    </parameters>

    <parameters>
        <label>anisoParam</label>
        <description>Gradient based anisotropic diffusion parameters</description>
        <double>
            <name>conductance</name>
            <longflag>conductance</longflag>
            <label>conductance</label>
            <description>The lower the value of conductance, the more strongly the filter preserves the original image's light/dark boundaries</description>
            <default>1.0</default>
        </double>
        <double>
            <name>timeStep</name>
            <longflag>timeStep</longflag>
            <label>time steps</label>
            <description>Adjust delta t in the equation given at https://docs.itk.org/projects/doxygen/en/stable/classitk_1_1AnisotropicDiffusionFunction.html. 
            Stable values for most 2D and 3D functions are 0.125 and 0.0625, respectively.</description>
            <default>0.125</default>
        </double>
        <integer>
            <longflag>iterations</longflag>
            <label>number of iterations</label>
            <description>How many times to filter the image sequentially with the anisotropic diffusion filter.</description>
            <default>1</default>
        </integer>
    </parameters>
</executable>
