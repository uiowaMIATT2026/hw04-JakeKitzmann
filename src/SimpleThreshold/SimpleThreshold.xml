<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.jkitzmann</category>
    <title>SimpleThresholder</title>
    <description>
        Simple image threshold.
    </description>
    <version>0.0.1</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Hans J. Johnson, Jacob J. Kitzmann</contributor>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>inputVolume</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
            <default>in.nii.gz</default>
        </image>
        <image>
            <name>outputVolume</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
            <default>thresholded.nii.gz</default>
        </image>
    </parameters>

    <parameters>
        <label>Thresholding</label>
        <description>Thresholding parameters</description>
        <integer>
            <name>lowThreshold</name>
            <longflag>lowThreshold</longflag>
            <label>Lower threshold bound</label>
            <description>Lower threshold of pass range</description>
            <default>0</default>
        </integer>
        <integer>
            <name>highThreshold</name>
            <longflag>highThreshold</longflag>
            <label>Higher threshold bound</label>
            <description>Upper threshold of pass range</description>
            <default>100</default>
        </integer>
        <integer>
            <name>insideValue</name>
            <longflag>insideValue</longflag>
            <label>Value inside of the threshold band</label>
            <description>Value for pixels inside the given range</description>
            <default>1</default>
        </integer>
        <integer>
            <name>outsideValue</name>
            <longflag>outsideValue</longflag>
            <label>Outside Value</label>
            <description>Value for pixels outside given range. Generally good practice to make a non-zero value.</description>
            <default>-101</default>
        </integer>
    </parameters>
</executable>
